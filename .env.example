# ================================================
# LangGraph 智能客服系统 — 环境变量配置
# ================================================
# 使用说明:
#   1. 复制此文件并重命名为 .env
#   2. 填写下方对应的 API Key 和配置项
#   3. 请勿将 .env 文件提交到版本控制系统
# ================================================

# ── 阿里云百炼 (DashScope) API Key ──
# 获取地址: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# ── LLM 模型选择 ──
# 可选: qwen-plus (推荐), qwen-max (最强), qwen-turbo (最快)
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ── 服务端口配置 ──
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── 知识库路径 ──
KNOWLEDGE_BASE_PATH=data/knowledge_base.txt
